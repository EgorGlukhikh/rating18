# Сервер
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5500

# База данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rating_db
DB_USER=rating_app
DB_PASSWORD=your_secure_password_here

# Redis (кеширование)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT токены
JWT_SECRET=your_very_long_random_secret_key_min_32_chars_CHANGE_THIS
JWT_EXPIRES_IN=7d

# Telegram авторизация
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_ID=123456789

# MAX авторизация (если доступно API)
MAX_CLIENT_ID=your_max_client_id
MAX_CLIENT_SECRET=your_max_client_secret
MAX_REDIRECT_URI=http://localhost:3000/api/auth/max/callback

# Email настройки (SMTP)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.ru
SMTP_PASSWORD=your_smtp_password
SMTP_FROM="Народный Рейтинг Удмуртии <noreply@yourdomain.ru>"

# Загрузка файлов
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
VOTE_RATE_LIMIT=10

# Безопасность
CORS_ORIGIN=http://localhost:5500
COOKIE_SECRET=your_cookie_secret_here

# Логирование
LOG_LEVEL=info
LOG_DIR=./logs

# Admin (первичный администратор)
ADMIN_EMAIL=admin@yourdomain.ru
ADMIN_PASSWORD=change_this_secure_password
