NODE_ENV=development
PORT=3000

# URL фронтенда для редиректов после авторизации
FRONTEND_URL=http://localhost:3000

# CORS: можно оставить true для same-origin, либо указать точный домен
CORS_ORIGIN=http://localhost:3000
COOKIE_SECRET=change_this_cookie_secret

# JWT
JWT_SECRET=change_this_super_long_secret_at_least_32_chars
JWT_EXPIRES_IN=30d

# Telegram Login
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_MAX_AUTH_AGE_SEC=86400

# Telegram ID админов через запятую
ADMIN_TELEGRAM_IDS=

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
UPLOAD_DIR=./uploads
